class A
{
    public static void main(String[]args){
    java.util.Scanner sc=new java.util.Scanner(System.in);
    int n=sc.nextInt();
    int n1=sc.nextInt();
    int c=1;
    if(n>n1){
        System.out.println("INVALID RANGE");
    }else{
    for(int i=n;i<=n1;i++)
    {
        if(i%11==0)
    {
        System.out.print(i+" ");
        c++;
    }
    }if(c==1)
    {
        System.out.println("NO NUMBERS");
    }
    }
    }
    
}
