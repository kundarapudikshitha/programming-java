class Main
{
    public static void main(String []args)
    {
        java.util.Scanner sc=new java.util.Scanner(System.in);
        int a=sc.nextInt();
        int b=sc.nextInt();
        int c=0;
        if(a<=0 || a>=b){
            System.out.print("Invalid Inputs");
        }else{
            for(int i=a+1;i<b;i++){
            if(i%2==0)  {
              if(c%2==0){
                  System.out.print(i+" ");
              }c++;
            }  
            }
        }
    }
}
