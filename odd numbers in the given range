import java.util.Scanner;
class A{
    public static void main(String[]args){
        Scanner sc=new Scanner(System.in);
        int a=sc.nextInt();
        int b=sc.nextInt();
        if(a>b){
            System.out.print("INVALID RANGE");
        }else{
        for(int i=a;i<=b;i++){
            if(i%2==1){
                System.out.print(i+" ");
            }
        }
    }
    }
}
